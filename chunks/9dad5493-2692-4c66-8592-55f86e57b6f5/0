function fileStoragePath(scope, username, folder, sub, file) {
  const sf = sanitizePath(folder), ss = sanitizePath(sub), sf2 = sanitizePath(file);
  const prefix = scope==='public' ? 'public_files' : `private_files/${encodeURIComponent(username)}`;
  return `${prefix}/${encodeURIComponent(sf)}/${encodeURIComponent(ss)}/${encodeURIComponent(sf2)}`;
}

// 合并文件夹密码（保留旧密码哈希）
function mergeFolderSecurity(oldFolders, newFolders) {
  return newFolders.map(nf => {
    const old = oldFolders.find(f => f.id === nf.id);
    return {
      ...nf,
      passwordHash: old ? old.passwordHash : (nf.passwordHash || ''),
      passwordSalt: old ? old.passwordSalt : (nf.passwordSalt || '')
    };
  });
}

// ==================== 认证中间件（含设备绑定） ====================
async function requireAuth(request, env, type='full') {
  const auth = request.headers.get('Authorization')||'';
  if (!auth.startsWith('Bearer ')) return null;
  const token = auth.slice(7);
  const payload = await verifyJWT(token, env.JWT_SECRET);
  if (!payload) return null;
  if (payload.jti && isBlacklisted(payload.jti)) return null;
  const currentIP = getClientIP(request);
  const currentUA = getUAHash(request);
  if (payload.ip && payload.ip !== currentIP) return null;
  if (payload.ua && payload.ua !== currentUA) return null;
  if (type==='full' && payload.type!=='full') return null;
  return payload;
}

// ==================== 主 Worker ====================
export default {
  async fetch(request, env) {
    if (request.method==='OPTIONS') return new Response(null, { headers:corsHeaders });
    if (!env.GITHUB_TOKEN_SECRET) throw new Error('GITHUB_TOKEN_SECRET missing');
    if (!env.JWT_SECRET) throw new Error('JWT_SECRET missing');
    const GITHUB_TOKEN = env.GITHUB_TOKEN_SECRET;
    const JWT_SECRET = env.JWT_SECRET;
    const url = new URL(request.url);
    const path = url.pathname;
    const ip = getClientIP(request);
    const uaHash = getUAHash(request);
    const storage = new GitHubStorage(GITHUB_TOKEN);

    try {
      // ==================== 公开路由 ====================
      if (path==='/register' && request.method==='POST') {
        const rl = checkRateLimit(ip, 'register', 3, 3600000);
        if (!rl.allowed) return json({ success:false, error:'注册次数过多，请稍后再试' }, 429);
        const { username, password, secondPassword, inviteCode, email } = await request.json();
        if (!username || !password || !secondPassword) return json({ success:false, error:'缺少必填项' }, 400);
        const users = await storage.readJSON('users.json', []);
        if (!Array.isArray(users)) return json({ success:false, error:'系统错误' }, 500);
        let role = INVITE_CODES[inviteCode] || null;
        if (!role) { const inviter = users.find(u=>u.inviteCode===inviteCode); if (inviter) role = inviter.role || 'admin'; }
        if (!role) return json({ success:false, error:'邀请码错误' }, 400);
        if (username.length<4||username.length>20) return json({ success:false, error:'用户名需4-20字符' }, 400);
        if (password.length<6) return json({ success:false, error:'密码至少6位' }, 400);
        if (!/^\d{6}$/.test(secondPassword)) return json({ success:false, error:'二级密码必须为6位数字' }, 400);
        if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return json({ success:false, error:'邮箱格式错误' }, 400);
        if (users.find(u=>u.username===username)) return json({ success:false, error:'用户名已存在' }, 400);
        if (email && users.some(u=>u.email===email)) return json({ success:false, error:'邮箱已被使用' }, 400);
        let myInviteCode; do { myInviteCode = generateInviteCode(); } while (users.some(u=>u.inviteCode===myInviteCode)||INVITE_CODES[myInviteCode]);
        const salt = crypto.randomUUID(), secondSalt = crypto.randomUUID();
        const newUser = { username, email:email||'', passwordHash:await hashPassword(password,salt), secondHash:await hashPassword(secondPassword,secondSalt), salt, secondSalt, hashVersion:'pbkdf2', role, inviteCode:myInviteCode, avatar:'', background:'' };
        users.push(newUser);
        let fs = await storage.readJSON('fileSystem.json', { public:createDefaultPublicFS(), private:{} });
        if (!fs.private) fs.private = {};
        fs.private[username] = createDefaultPrivateFS();
        const uSha = (await storage.request('users.json'))?.sha;
        const fSha = (await storage.request('fileSystem.json'))?.sha;
        const w1 = await storage.writeJSON('users.json', users, uSha);
        if (w1?.conflict) return json({ success:false, error:'系统繁忙，请稍后重试' }, 409);
        const w2 = await storage.writeJSON('fileSystem.json', fs, fSha);
        if (w2?.conflict) return json({ success:false, error:'系统繁忙，请稍后重试' }, 409);
        addAuditLog('register', username, ip);
        return json({ success:true, data:{ inviteCode:myInviteCode } });
      }

      if (path==='/login' && request.method==='POST') {
        const rl = checkRateLimit(ip, 'login', 5, 10 * 60000);
        if (!rl.allowed) return json({ success:false, error:'登录尝试过多，请稍后再试' }, 429);
        const { username, password } = await request.json();
        if (!username || !password) return json({ success:false, error:'账号密码不能为空' }, 400);
        const users = await storage.readJSON('users.json', []);
        const user = users.find(u=>u.username===username || u.email===username);
        if (!user) return json({ success:false, error:'账号或密码错误' }, 401);
        const ok = (await hashPassword(password, user.salt)) === user.passwordHash;
        if (!ok) return json({ success:false, error:'账号或密码错误' }, 401);
        clearRateLimit(ip, 'login');
        const partialToken = await signJWT({
          username:user.username, role:user.role, type:'partial',
          iat:Math.floor(Date.now()/1000), exp:Math.floor(Date.now()/1000)+PARTIAL_EXPIRY,
          jti:crypto.randomUUID(), ip, ua:uaHash
        }, JWT_SECRET);
        return json({ success:true, data:{ partialToken, username:user.username, email:user.email, role:user.role, avatar:user.avatar||'' } });
      }

      if (path==='/verify-second-password' && request.method==='POST') {
        const rl = checkRateLimit(ip, '2fa', 3, 10 * 60000);
        if (!rl.allowed) return json({ success:false, error:'验证尝试过多，请稍后再试' }, 429);
        const partial = await requireAuth(request, env, 'partial');
        if (!partial) return json({ success:false, error:'请先完成第一步登录' }, 401);
        const { secondPassword } = await request.json();
        if (!secondPassword) return json({ success:false, error:'参数错误' }, 400);
        const users = await storage.readJSON('users.json', []);
        const user = users.find(u=>u.username===partial.username);
        if (!user) return json({ success:false, error:'用户不存在' }, 401);
        const salt = user.secondSalt||user.salt;
        const ok = (await hashPassword(secondPassword, salt)) === user.secondHash;
        if (!ok) return json({ success:false, error:'二级密码错误' }, 401);
        clearRateLimit(ip, '2fa');
        clearRateLimit(ip, 'login');
        const fullToken = await signJWT({
          username:user.username, role:user.role, type:'full',
          iat:Math.floor(Date.now()/1000), exp:Math.floor(Date.now()/1000)+TOKEN_EXPIRY,
          jti:crypto.randomUUID(), ip, ua:uaHash
        }, JWT_SECRET);
        addAuditLog('login_success', user.username, ip);
        return json({ success:true, data:{ token:fullToken, username:user.username, email:user.email, role:user.role, inviteCode:user.inviteCode, avatar:user.avatar||'', background:user.background||'' } });
      }

      // ==================== 需要完整 token 的路由 ====================
      const auth = await requireAuth(request, env, 'full');
      if (!auth) return json({ success:false, error:'未授权，请重新登录' }, 401);

      if (path==='/logout' && request.method==='POST') {
        const token = (request.headers.get('Authorization')||'').slice(7);
        const payload = await verifyJWT(token, JWT_SECRET);
        if (payload?.jti) addToBlacklist(payload.jti, payload.exp);
        addAuditLog('logout', auth.username, ip);
        return json({ success:true, data:{} });
      }

      if (path==='/me' && request.method==='GET') {
        const users = await storage.readJSON('users.json', []);
        const user = users.find(u=>u.username===auth.username);
        if (!user) return json({ success:false, error:'用户不存在' }, 404);
        return json({ success:true, data:{ username:user.username, email:user.email, role:user.role, inviteCode:user.inviteCode, avatar:user.avatar||'', background:user.background||'' } });
      }

      if (path==='/get-fs' && request.method==='GET') {
        let fs = await storage.readJSON('fileSystem.json', null);
        if (!fs || !fs.public) { fs = { public:createDefaultPublicFS(), private:{} }; await storage.writeJSON('fileSystem.json', fs, (await storage.request('fileSystem.json'))?.sha); }
        if (!fs.private) fs.private = {};
        if (!fs.private[auth.username]) { fs.private[auth.username] = createDefaultPrivateFS(); await storage.writeJSON('fileSystem.json', fs, (await storage.request('fileSystem.json'))?.sha); }
        const safePublic = fs.public.folders.map(f=>({ id:f.id, name:f.name, hasPassword:!!f.passwordHash, children:f.children||[] }));
        const safePrivate = fs.private[auth.username].folders.map(f=>({ id:f.id, name:f.name, hasPassword:!!f.passwordHash, children:f.children||[] }));
        return json({ success:true, data:{ public:{ ...fs.public, folders:safePublic }, private:{ ...fs.private[auth.username], folders:safePrivate }, username:auth.username, role:auth.role, version:fs.public.version } });
      }

      if (path==='/update-fs' && request.method==='PUT') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, folders, trash, version } = await request.json();
        if (!scope || !['public','private'].includes(scope)) return json({ success:false, error:'无效作用域' }, 400);
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        if (version!==undefined && container.version!==version) return json({ success:false, error:'文件已被修改，请刷新' }, 409);
        // 合并旧文件夹密码
        const mergedFolders = mergeFolderSecurity(container.folders, folders);
        container.folders = mergedFolders;
        container.trash = trash||[];
        container.version = (container.version||0)+1;
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突，请刷新后重试' }, 409);
        return json({ success:true, data:{ version:container.version } });
      }

      if (path==='/set-folder-password' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, folderId, password } = await request.json();
        if (!scope || !folderId) return json({ success:false, error:'参数错误' }, 400);
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const folder = container.folders.find(f=>f.id===folderId);
        if (!folder) return json({ success:false, error:'文件夹不存在' }, 404);
        if (password) { const s = crypto.randomUUID(); folder.passwordHash = await hashPassword(password, s); folder.passwordSalt = s; }
        else { folder.passwordHash = ''; folder.passwordSalt = ''; }
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突，请刷新' }, 409);
        return json({ success:true, data:{} });
      }

      if (path==='/verify-folder-password' && request.method==='POST') {
        const { scope, folderId, password } = await request.json();
        if (!scope || !folderId || !password) return json({ success:false, error:'参数错误' }, 400);
        const fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const folder = container.folders.find(f=>f.id===folderId);
        if (!folder) return json({ success:false, error:'文件夹不存在' }, 404);
        if (!folder.passwordHash) return json({ success:true, data:{} });
        const ok = (await hashPassword(password, folder.passwordSalt)) === folder.passwordHash;
        if (!ok) return json({ success:false, error:'密码错误' }, 401);
        return json({ success:true, data:{} });
      }

      if (path==='/move-to-trash' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, type, folderId, subId, fileName } = await request.json();
        if (!scope || !type || !folderId) return json({ success:false, error:'参数错误' }, 400);
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        if (!container.trash) container.trash = [];
        if (type==='file') {
          const fo = container.folders.find(f=>f.id===folderId);
          if (!fo) return json({ success:false, error:'文件夹不存在' }, 404);
          const sub = fo.children.find(c=>c.id===subId);
          if (!sub) return json({ success:false, error:'子分类不存在' }, 404);
          const idx = sub.files.findIndex(f=>f.name===fileName);
          if (idx===-1) return json({ success:false, error:'文件不存在' }, 404);
          const [obj] = sub.files.splice(idx,1);
          container.trash.push({ type:'file', folderId, folderName:fo.name, subId, subName:sub.name, file:obj, deletedAt:Date.now() });
        } else if (type==='sub') {
          const fo = container.folders.find(f=>f.id===folderId);
          if (!fo) return json({ success:false, error:'文件夹不存在' }, 404);
          const idx = fo.children.findIndex(c=>c.id===subId);
          if (idx===-1) return json({ success:false, error:'子分类不存在' }, 404);
          const [obj] = fo.children.splice(idx,1);
          container.trash.push({ type:'sub', folderId, folderName:fo.name, sub:obj, deletedAt:Date.now() });
        } else if (type==='folder') {
          const idx = container.folders.findIndex(f=>f.id===folderId);
          if (idx===-1) return json({ success:false, error:'文件夹不存在' }, 404);
          const [obj] = container.folders.splice(idx,1);
          container.trash.push({ type:'folder', folder:obj, deletedAt:Date.now() });
        }
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突' }, 409);
        addAuditLog(`move_to_trash_${type}`, auth.username, ip);
        return json({ success:true, data:{} });
      }

      // /delete-file 直接删除（不移入回收站）
      if (path==='/delete-file' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, folderId, subId, fileName } = await request.json();
        if (!scope || !folderId || !subId || !fileName) return json({ success:false, error:'参数错误' }, 400);
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const folder = container.folders.find(f=>f.id===folderId);
        if (!folder) return json({ success:false, error:'文件夹不存在' }, 404);
        const sub = folder.children.find(c=>c.id===subId);
        if (!sub) return json({ success:false, error:'子分类不存在' }, 404);
        const idx = sub.files.findIndex(f=>f.name===fileName);
        if (idx===-1) return json({ success:false, error:'文件不存在' }, 404);
        sub.files.splice(idx,1);
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突' }, 409);
        const username = auth.username;
        await storage.deleteFile(fileStoragePath(scope, username, folder.name, sub.name, fileName), null);
        addAuditLog('delete_file', auth.username, ip);
        return json({ success:true, data:{} });
      }

      if (path==='/restore-from-trash' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, index } = await request.json();
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const item = container.trash?.[index];
        if (!item) return json({ success:false, error:'无效项目' }, 404);
        if (item.type==='file') {
          let tf = container.folders.find(f=>f.id===item.folderId);
          if (!tf) { tf = { id:item.folderId, name:item.folderName||'已删除', passwordHash:'', passwordSalt:'', children:[] }; container.folders.push(tf); }
          let ts = tf.children.find(c=>c.id===item.subId);
          if (!ts) { ts = { id:item.subId||crypto.randomUUID(), name:item.subName||'已删除', files:[] }; tf.children.push(ts); }
          ts.files.push(item.file);
        } else if (item.type==='sub') {
          let tf = container.folders.find(f=>f.id===item.folderId);
          if (!tf) { tf = { id:item.folderId, name:item.folderName||'已删除', passwordHash:'', passwordSalt:'', children:[] }; container.folders.push(tf); }
          tf.children.push(item.sub);
        } else if (item.type==='folder') {
          container.folders.push(item.folder);
        }
        container.trash.splice(index,1);
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突' }, 409);
        return json({ success:true, data:{} });
      }

      if (path==='/permanent-delete' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, index } = await request.json();
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const item = container.trash?.[index];
        if (!item) return json({ success:false, error:'项目不存在' }, 404);
        const username = auth.username;
        if (item.type==='file') {
          const fo = container.folders.find(f=>f.id===item.folderId);
          const so = fo?.children?.find(c=>c.id===item.subId);
          if (fo && so) await storage.deleteFile(fileStoragePath(scope, username, fo.name, so.name, item.file.name), null);
        } else if (item.type==='sub') {
          const fo = container.folders.find(f=>f.id===item.folderId);
          if (fo) for (const f of item.sub.files) await storage.deleteFile(fileStoragePath(scope, username, fo.name, item.sub.name, f.name), null);
        } else if (item.type==='folder') {
          for (const c of item.folder.children) for (const f of c.files) await storage.deleteFile(fileStoragePath(scope, username, item.folder.name, c.name, f.name), null);
        }
        container.trash.splice(index,1);
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突' }, 409);
        addAuditLog('permanent_delete', auth.username, ip);
        return json({ success:true, data:{} });
      }

      if (path==='/empty-trash' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope } = await request.json();
        if (!scope || !['public','private'].includes(scope)) return json({ success:false, error:'无效作用域' }, 400);
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const username = auth.username;
        for (const item of container.trash||[]) {
          if (item.type==='file') {
            const fo = container.folders.find(f=>f.id===item.folderId);
            const so = fo?.children?.find(c=>c.id===item.subId);
            if (fo && so) await storage.deleteFile(fileStoragePath(scope, username, fo.name, so.name, item.file.name), null);
          } else if (item.type==='sub') {
            const fo = container.folders.find(f=>f.id===item.folderId);
            if (fo) for (const f of item.sub.files) await storage.deleteFile(fileStoragePath(scope, username, fo.name, item.sub.name, f.name), null);
          } else if (item.type==='folder') {
            for (const c of item.folder.children) for (const f of c.files) await storage.deleteFile(fileStoragePath(scope, username, item.folder.name, c.name, f.name), null);
          }
        }
        container.trash = [];
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突' }, 409);
        addAuditLog('empty_trash', auth.username, ip);
        return json({ success:true, data:{} });
      }

      if (path==='/rename-folder' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, folderId, newName } = await request.json();
        if (!scope || !folderId || !newName || !validFileName(newName)) return json({ success:false, error:'参数错误' }, 400);
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const folder = container.folders.find(f=>f.id===folderId);
        if (!folder) return json({ success:false, error:'文件夹不存在' }, 404);
        const oldName = folder.name;
        folder.name = newName;
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突' }, 409);
        const username = auth.username;
        const prefix = scope==='public' ? 'public_files' : `private_files/${encodeURIComponent(username)}`;
        const oldPrefix = `${prefix}/${encodeURIComponent(oldName)}/`;
        const files = await storage.listFiles(oldPrefix);
        for (const fp of files) {
          const newPath = fp.replace(oldPrefix, `${prefix}/${encodeURIComponent(newName)}/`);
          const content = await storage.getContent(fp);
          const exNew = await storage.request(newPath);
          await storage.uploadFile(newPath, btoa(content), exNew?.sha);
          const oldObj = await storage.request(fp);
          if (oldObj?.sha) await storage.deleteFile(fp, oldObj.sha);
        }
        return json({ success:true, data:{ moved:files.length } });
      }

      if (path==='/rename-sub' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, folderId, subId, newSub } = await request.json();
        if (!scope || !folderId || !subId || !newSub || !validFileName(newSub)) return json({ success:false, error:'参数错误' }, 400);
        let fs = await storage.readJSON('fileSystem.json');
        const container = scope==='public' ? fs.public : (fs.private?.[auth.username]||createDefaultPrivateFS());
        const folder = container.folders.find(f=>f.id===folderId);
        if (!folder) return json({ success:false, error:'文件夹不存在' }, 404);
        const sub = folder.children.find(c=>c.id===subId);
        if (!sub) return json({ success:false, error:'子分类不存在' }, 404);
        const oldName = sub.name;
        sub.name = newSub;
        const sha = (await storage.request('fileSystem.json'))?.sha;
        const wRes = await storage.writeJSON('fileSystem.json', fs, sha);
        if (wRes?.conflict) return json({ success:false, error:'冲突' }, 409);
        const username = auth.username;
        const prefix = scope==='public' ? 'public_files' : `private_files/${encodeURIComponent(username)}`;
        const oldPrefix = `${prefix}/${encodeURIComponent(folder.name)}/${encodeURIComponent(oldName)}/`;
        const files = await storage.listFiles(oldPrefix);
        for (const fp of files) {
          const newPath = fp.replace(oldPrefix, `${prefix}/${encodeURIComponent(folder.name)}/${encodeURIComponent(newSub)}/`);
          const content = await storage.getContent(fp);
          const exNew = await storage.request(newPath);
          await storage.uploadFile(newPath, btoa(content), exNew?.sha);
          const oldObj = await storage.request(fp);
          if (oldObj?.sha) await storage.deleteFile(fp, oldObj.sha);
        }
        return json({ success:true, data:{ moved:files.length } });
      }

      // ==================== 上传（含后端大小校验） ====================
      if (path==='/upload-chunk' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, fileName, folder, subFolder, chunkIndex, totalChunks, data, mime, uploadId } = await request.json();
        if (!scope || !validFileName(fileName) || !folder || !subFolder) return json({ success:false, error:'参数无效' }, 400);
        // 分片大小限制（单分片不超过10MB）
        if (data.length > 10 * 1024 * 1024) return json({ success:false, error:'分片过大' }, 400);
        const username = auth.username;
        const uid = uploadId || crypto.randomUUID();
        const chunkPath = `chunks/${uid}/${chunkIndex}`;
        const ex = await storage.request(chunkPath);
        await storage.uploadFile(chunkPath, data, ex?.sha);
        if (chunkIndex === totalChunks - 1) {
          if (totalChunks * 10 * 1024 * 1024 > MAX_UPLOAD_SIZE + 10 * 1024 * 1024) return json({ success:false, error:'文件总大小超过限制' }, 400);
          const chunks = [];
          for (let i=0; i<totalChunks; i++) {
            const r = await storage.getContent(`chunks/${uid}/${i}`);
            if (!r) throw new Error(`缺失分片 ${i}`);
            chunks.push(r);
          }
          const full = chunks.join('');
          if (full.length > MAX_UPLOAD_SIZE) return json({ success:false, error:'文件过大' }, 400);
          const targetPath = fileStoragePath(scope, username, folder, subFolder, fileName);
          const exFile = await storage.request(targetPath);
          await storage.uploadFile(targetPath, full, exFile?.sha);
          for (let i=0; i<totalChunks; i++) {
            const cp = `chunks/${uid}/${i}`;
            const cm = await storage.request(cp);
            if (cm?.sha) await storage.deleteFile(cp, cm.sha);
          }
          addAuditLog('upload_file', auth.username, ip);
          return json({ success:true, data:{ merged:true } });
        }
        return json({ success:true, data:{ uploadId:uid } });
      }

      if (path==='/download-file' && request.method==='GET') {
        const scope = url.searchParams.get('scope')||'public';
        const folder = url.searchParams.get('folder');
        const sub = url.searchParams.get('sub');
        const file = url.searchParams.get('file');
        if (!folder || !sub || !file) return json({ success:false, error:'缺少参数' }, 400);
        const username = auth.username;
        const fpath = fileStoragePath(scope, username, folder, sub, file);
        const content = await storage.getContent(fpath);
        if (!content) return json({ success:false, error:'文件不存在' }, 404);
        return new Response(content, { headers: { 'Content-Type':'application/octet-stream', 'Content-Disposition':`attachment; filename="${file}"`, ...corsHeaders } });
      }

      if (path==='/edit-file' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { scope, folder, subFolder, fileName, content } = await request.json();
        if (!scope || !folder || !subFolder || !validFileName(fileName)) return json({ success:false, error:'参数错误' }, 400);
        const str = String(content);
        if (str.length > MAX_EDIT_SIZE) return json({ success:false, error:`内容超过${MAX_EDIT_SIZE/1024}KB` }, 400);
        const username = auth.username;
        const target = fileStoragePath(scope, username, folder, subFolder, fileName);
        const ex = await storage.request(target);
        if (!ex) return json({ success:false, error:'文件不存在' }, 404);
        const encoded = btoa(unescape(encodeURIComponent(str)));
        await storage.uploadFile(target, encoded, ex.sha);
        return json({ success:true, data:{} });
      }

      if (path==='/upload-avatar' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { data, mime } = await request.json();
        if (!data || !mime) return json({ success:false, error:'缺少数据' }, 400);
        if (data.length > MAX_AVATAR_SIZE) return json({ success:false, error:'头像图片不能超过500KB' }, 400);
        const ext = mime.split('/')[1]||'png';
        const fileName = `avatar_${auth.username}_${Date.now()}.${ext}`;
        const avatarPath = `avatars/${fileName}`;
        await storage.uploadFile(avatarPath, data);
        const avatarUrl = `https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${BRANCH}/${avatarPath}`;
        const users = await storage.readJSON('users.json', []);
        const idx = users.findIndex(u=>u.username===auth.username);
        if (idx!==-1) { users[idx].avatar = avatarUrl; await storage.writeJSON('users.json', users, (await storage.request('users.json'))?.sha); }
        return json({ success:true, data:{ avatarUrl } });
      }

      if (path==='/upload-background' && request.method==='POST') {
        if (auth.role==='readonly') return json({ success:false, error:'权限不足' }, 403);
        const { data, mime } = await request.json();
        if (!data || !mime) return json({ success:false, error:'缺少数据' }, 400);
        if (data.length > MAX_BG_SIZE) return json({ success:false, error:'背景图片不能超过2MB' }, 400);
        const bgPath = `backgrounds/${auth.username}.webp`;
        const ex = await storage.request(bgPath);
        await storage.uploadFile(bgPath, data, ex?.sha);
        const bgUrl = `https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${BRANCH}/${bgPath}?t=${Date.now()}`;
        const users = await storage.readJSON('users.json', []);
        const idx = users.findIndex(u=>u.username===auth.username);
        if (idx!==-1) { users[idx].background = bgUrl; await storage.writeJSON('users.json', users, (await storage.request('users.json'))?.sha); }
        return json({ success:true, data:{ backgroundUrl:bgUrl } });
      }

      // ==================== 修改资料（含用户名迁移） ====================
      if (path==='/update-profile' && request.method==='POST') {
        const { oldPassword, newPassword, oldSecondPassword, newSecondPassword, newUsername, avatar } = await request.json();
        let users = await storage.readJSON('users.json', []);
        const idx = users.findIndex(u=>u.username===auth.username);
        if (idx===-1) return json({ success:false, error:'用户不存在' }, 404);
        if (newPassword) {
          if (!oldPassword) return json({ success:false, error:'需要原密码' }, 400);
          if ((await hashPassword(oldPassword, users[idx].salt)) !== users[idx].passwordHash) return json({ success:false, error:'原密码错误' }, 401);
          if (newPassword.length<6) return json({ success:false, error:'新密码至少6位' }, 400);
          users[idx].passwordHash = await hashPassword(newPassword, users[idx].salt);
          addAuditLog('change_password', auth.username, ip);
        }
        if (newSecondPassword) {
          if (!oldSecondPassword) return json({ success:false, error:'需要原二级密码' }, 400);
          const ss = users[idx].secondSalt||users[idx].salt;
          if ((await hashPassword(oldSecondPassword, ss)) !== users[idx].secondHash) return json({ success:false, error:'原二级密码错误' }, 401);
          if (!/^\d{6}$/.test(newSecondPassword)) return json({ success:false, error:'二级密码需6位数字' }, 400);
          const nss = crypto.randomUUID();
          users[idx].secondHash = await hashPassword(newSecondPassword, nss);
          users[idx].secondSalt = nss;
          addAuditLog('change_second_password', auth.username, ip);
        }
        if (newUsername && newUsername!==auth.username) {
          if (newUsername.length<4||newUsername.length>20) return json({ success:false, error:'用户名4-20字符' }, 400);
          if (users.find((u,i)=>i!==idx && u.username===newUsername)) return json({ success:false, error:'用户名已存在' }, 400);
          const oldUsername = users[idx].username;
          users[idx].username = newUsername;
          // 迁移私有空间
          let fs = await storage.readJSON('fileSystem.json');
          if (fs && fs.private && fs.private[oldUsername]) {
            fs.private[newUsername] = fs.private[oldUsername];
            delete fs.private[oldUsername];
            await storage.writeJSON('fileSystem.json', fs, (await storage.request('fileSystem.json'))?.sha);
          }
          addAuditLog('change_username', auth.username, ip);
        }
        if (avatar!==undefined) {
          if (avatar && !avatar.startsWith('https://')) return json({ success:false, error:'头像地址必须以 https:// 开头' }, 400);
          users[idx].avatar = avatar||'';
        }
        const sha = (await storage.request('users.json'))?.sha;
        const wRes = await storage.writeJSON('users.json', users, sha);
        if (wRes?.conflict) return json({ success:false, error:'系统繁忙，请稍后重试' }, 409);
        const newToken = await signJWT({
          username:users[idx].username, role:users[idx].role, type:'full',
          iat:Math.floor(Date.now()/1000), exp:Math.floor(Date.now()/1000)+TOKEN_EXPIRY,
          jti:crypto.randomUUID(), ip, ua:uaHash
        }, JWT_SECRET);
        return json({ success:true, data:{ token:newToken, newUsername:users[idx].username, avatar:users[idx].avatar } });
      }

      if (path==='/search' && request.method==='POST') {
        const { query, scope } = await request.json();
        if (!query || query.length<2) return json({ success:false, error:'关键词至少2个字符' }, 400);
        const fs = await storage.readJSON('fileSystem.json');
        if (!fs) return json({ success:true, data:{ results:[] } });
        const results = [];
        const lowerQuery = query.toLowerCase();
        const maxFileSize = 500 * 1024;
        async function searchContainer(container, s, username) {
          if (!container?.folders) return;
          for (const folder of container.folders) {
            if (!folder.children) continue;
            for (const sub of folder.children) {
              if (!sub.files) continue;
              for (const file of sub.files) {
                const isText = /\.(txt|md|json|csv|py|js|html|css|log|xml|yaml)$/i.test(file.name);
                if (!isText) continue;
                if (file.size && file.size > maxFileSize) continue;
                if (file.name.toLowerCase().includes(lowerQuery)) {
                  results.push({ scope:s, folder:folder.name, sub:sub.name, file:file.name, matchType:'filename', context:'' });
                  continue;
                }
                try {
                  const content = await storage.getContent(fileStoragePath(s, username, folder.name, sub.name, file.name));
                  if (content && content.toLowerCase().includes(lowerQuery)) {
                    const idx = content.toLowerCase().indexOf(lowerQuery);
                    const start = Math.max(0, idx-30), end = Math.min(content.length, idx+query.length+30);
                    results.push({ scope:s, folder:folder.name, sub:sub.name, file:file.name, matchType:'content', context:content.substring(start,end) });
                  }
                } catch {}
              }
            }
          }
        }
        if (!scope || scope==='public') await searchContainer(fs.public, 'public', '');
        if (!scope || scope==='private') if (fs.private?.[auth.username]) await searchContainer(fs.private[auth.username], 'private', auth.username);
        return json({ success:true, data:{ results } });
      }

      return new Response('Not Found', { status:404, headers:corsHeaders });
    } catch (err) {
      console.error(err);
      return json({ success:false, error:'服务器内部错误' }, 500);
    }
  }
};