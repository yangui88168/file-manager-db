// ==================== 工具函数 ====================
function json(data, status = 200) {
  return new Response(JSON.stringify(data), { status, headers: { 'Content-Type': 'application/json', ...corsHeaders } });
}

function generateInviteCode() {
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
  let code = '';
  for (let i = 0; i < 8; i++) code += chars.charAt(Math.floor(Math.random() * chars.length));
  return code;
}

function getClientIP(request) {
  return request.headers.get('CF-Connecting-IP') ||
         request.headers.get('X-Forwarded-For')?.split(',')[0]?.trim() ||
         request.headers.get('X-Real-IP') || 'unknown';
}

function getUAHash(request) {
  const ua = request.headers.get('User-Agent') || '';
  return btoa(ua).substring(0, 20);
}

function validFileName(name) {
  return typeof name === 'string' && name.length > 0 && name.length <= 200 && !name.includes('..') && !name.includes('/') && !name.includes('\\');
}

function sanitizePath(segment) {
  if (!segment || typeof segment !== 'string') throw new Error('Invalid path segment');
  const decoded = decodeURIComponent(segment);
  if (decoded.includes('..') || decoded.includes('\\')) throw new Error('Path traversal detected');
  return decoded;
}

async function hashPassword(password, salt) {
  const enc = new TextEncoder();
  const key = await crypto.subtle.importKey('raw', enc.encode(password), 'PBKDF2', false, ['deriveBits']);
  const buf = await crypto.subtle.deriveBits(
    { name: 'PBKDF2', salt: enc.encode(salt), iterations: 100000, hash: 'SHA-256' }, key, 256);
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
}

// ==================== JWT ====================
const b64u = s => btoa(s).replace(/=/g,'').replace(/\+/g,'-').replace(/\//g,'_');
const b64uDec = s => { s = s.replace(/-/g,'+').replace(/_/g,'/'); while (s.length % 4) s += '='; return atob(s); };

async function signJWT(payload, secret) {
  const h = b64u(JSON.stringify({ alg:'HS256', typ:'JWT' }));
  const p = b64u(JSON.stringify(payload));
  const data = `${h}.${p}`;
  const key = await crypto.subtle.importKey('raw', new TextEncoder().encode(secret), { name:'HMAC', hash:'SHA-256' }, false, ['sign']);
  const sig = await crypto.subtle.sign('HMAC', key, new TextEncoder().encode(data));
  const s = btoa(String.fromCharCode(...new Uint8Array(sig))).replace(/=/g,'').replace(/\+/g,'-').replace(/\//g,'_');
  return `${data}.${s}`;
}

async function verifyJWT(token, secret) {
  try {
    const parts = token.split('.');
    if (parts.length !== 3) return null;
    const [h, p, s] = parts;
    const key = await crypto.subtle.importKey('raw', new TextEncoder().encode(secret), { name:'HMAC', hash:'SHA-256' }, false, ['verify']);
    const sigBytes = Uint8Array.from(b64uDec(s), c => c.charCodeAt(0));
    const valid = await crypto.subtle.verify('HMAC', key, sigBytes, new TextEncoder().encode(`${h}.${p}`));
    if (!valid) return null;
    const payload = JSON.parse(b64uDec(p));
    if (payload.exp < Math.floor(Date.now() / 1000)) return null;
    return payload;
  } catch { return null; }
}

// ==================== 黑名单 ====================
const tokenBlacklist = new Map();
function addToBlacklist(jti, exp) {
  tokenBlacklist.set(jti, exp * 1000);
  for (const [k, t] of tokenBlacklist) if (Date.now() > t) tokenBlacklist.delete(k);
}
function isBlacklisted(jti) {
  if (!jti) return false;
  const expiry = tokenBlacklist.get(jti);
  if (!expiry) return false;
  if (Date.now() > expiry) { tokenBlacklist.delete(jti); return false; }
  return true;
}

// ==================== 限流与锁定 ====================
const rateLimitMap = new Map();
const failureLock = new Map();

function checkRateLimit(ip, action, max, windowMs) {
  const lock = failureLock.get(ip);
  if (lock && Date.now() < lock.lockUntil) {
    return { allowed: false, remaining: 0, locked: true };
  }
  const key = `${ip}:${action}`;
  const now = Date.now();
  const entry = rateLimitMap.get(key);
  if (!entry || now > entry.reset) {
    rateLimitMap.set(key, { count: 1, reset: now + windowMs });
    return { allowed: true, remaining: max - 1 };
  }
  if (entry.count >= max) {
    if (action === 'login' || action === '2fa') {
      failureLock.set(ip, { lockUntil: now + 30 * 60 * 1000, count: (lock?.count || 0) + 1 });
    }
    return { allowed: false, remaining: 0 };
  }
  entry.count++;
  return { allowed: true, remaining: max - entry.count };
}

function clearRateLimit(ip, action) {
  const key = `${ip}:${action}`;
  rateLimitMap.delete(key);
  failureLock.delete(ip);
}

// ==================== 审计日志 ====================
const auditLogs = [];
function addAuditLog(action, user, ip) {
  const entry = { time: new Date().toISOString(), user, ip, action };
  auditLogs.push(entry);
  if (auditLogs.length > 1000) auditLogs.shift();
  console.log(`AUDIT: ${JSON.stringify(entry)}`);
}

// ==================== GitHub 存储（带冲突重试） ====================
class GitHubStorage {
  constructor(token) { this.token = token; }
  base() { return `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}`; }
  async request(path, method='GET', body=null, retries=3) {
    const url = `${this.base()}/contents/${path}`;
    const hdrs = { 'Authorization':`token ${this.token}`, 'User-Agent':'CloudflareWorker', 'Content-Type':'application/json' };
    const opts = { method, headers: hdrs };
    if (body) opts.body = JSON.stringify(body);
    for (let attempt = 1; attempt <= retries; attempt++) {
      const res = await fetch(url, opts);
      if (res.status === 409 && attempt < retries) {
        await new Promise(r => setTimeout(r, 200 * attempt));
        continue;
      }
      if (res.status === 409) return { conflict: true };
      if (res.status === 404) return null;
      if (!res.ok) throw new Error(`GitHub ${method} ${path} (${res.status})`);
      const data = await res.json();
      if (data.content) {
    const binary = atob(data.content.replace(/\n/g, ''));
    const bytes = Uint8Array.from(binary, c => c.charCodeAt(0));
    data.content = new TextDecoder('utf-8').decode(bytes);
}
      return data;
    }
    return { conflict: true };
  }
  async readJSON(path, def=null) {
    const d = await this.request(path);
    if (d && !d.conflict && d.content) { try { return JSON.parse(d.content); } catch { return def; } }
    return def;
  }
  async writeJSON(path, data, sha=null) {
    const jsonText = JSON.stringify(data);
const bytes = new TextEncoder().encode(jsonText);

let binary = '';
for (const b of bytes) {
    binary += String.fromCharCode(b);
}

const content = btoa(binary);
    const body = { message:`Update ${path}`, content, branch:BRANCH };
    if (sha) body.sha = sha;
    const res = await this.request(path, 'PUT', body);
    if (res?.conflict) return { conflict:true };
    return res;
  }
  async uploadFile(path, b64content, sha=null) {
    const body = { message:`Upload ${path}`, content:b64content, branch:BRANCH };
    if (sha) body.sha = sha;
    const res = await this.request(path, 'PUT', body);
    if (res?.conflict) return { conflict:true };
    return res;
  }
  async deleteFile(path, sha) {
    const url = `${this.base()}/contents/${path}`;
    const res = await fetch(url, {
      method:'DELETE',
      headers: { 'Authorization':`token ${this.token}`, 'User-Agent':'CloudflareWorker', 'Content-Type':'application/json' },
      body: JSON.stringify({ message:`Delete ${path}`, sha, branch:BRANCH })
    });
    if (!res.ok) throw new Error(`Delete failed: ${await res.text()}`);
  }
  async getContent(path) { const d = await this.request(path); return d?.content || null; }
  async listFiles(prefix) {
    const url = `${this.base()}/git/trees/${BRANCH}?recursive=1`;
    const res = await fetch(url, { headers: { 'Authorization':`token ${this.token}`, 'User-Agent':'CloudflareWorker' } });
    if (!res.ok) throw new Error('Failed list tree');
    const data = await res.json();
    return data.tree.filter(f=>f.type==='blob' && f.path.startsWith(prefix)).map(f=>f.path);
  }
}

